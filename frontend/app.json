{
  "expo": {
    "name": "CRM-RECORDER",
    "slug": "crm-recorder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "crmrecorder",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crmrecorder.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Record calls for CRM monitoring",
        "NSContactsUsageDescription": "Identify callers in recordings"
      }
    },
    "android": {
      "package": "com.crmrecorder.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      },
      "permissions": [
        "RECORD_AUDIO",
        "READ_PHONE_STATE",
        "READ_CALL_LOG",
        "READ_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
